<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="TableViewNuGetSample.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TableViewNuGetSample.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tableView="using:WinUI.TableView"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="ExplorerNameTemplate">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon Glyph="{Binding IconGlyph}" FontSize="14" />
                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="TaskNameTemplate">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon Glyph="{Binding IconGlyph}" FontSize="14" />
                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ContactRowTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="20" Width="36" Height="36"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,8">
                    <TextBlock Text="{Binding Initials}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="White" FontWeight="SemiBold" FontSize="13" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,8,0,8">
                    <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Title}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding Email}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                <TextBlock Grid.Column="3" Text="{Binding Phone}" VerticalAlignment="Center" Margin="8,0,0,0" />
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4" Margin="8,0,0,0">
                    <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                            CornerRadius="4" Padding="8,2"
                            Visibility="{Binding IsOnline}">
                        <TextBlock Text="Online" FontSize="11" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="HighPriorityOrderTemplate">
            <Grid Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="8,8,0,8">
                    <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    <TextBlock Text="{Binding OrderId}" FontWeight="Bold" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Customer}" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                <TextBlock Grid.Column="2" Text="{Binding TotalDisplay}" VerticalAlignment="Center" FontWeight="Bold" Margin="8,0,0,0" />
                <Border Grid.Column="3" Background="{ThemeResource SystemFillColorCriticalBrush}" CornerRadius="4" Padding="8,2" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0">
                    <TextBlock Text="{Binding Priority}" FontSize="11" Foreground="White" />
                </Border>
                <TextBlock Grid.Column="4" Text="{Binding DateDisplay}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="8,0,0,0" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="NormalOrderTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding OrderId}" VerticalAlignment="Center" Margin="8,8,0,8" />
                <TextBlock Grid.Column="1" Text="{Binding Customer}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                <TextBlock Grid.Column="2" Text="{Binding TotalDisplay}" VerticalAlignment="Center" Margin="8,0,0,0" />
                <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="8,2" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0">
                    <TextBlock Text="{Binding Priority}" FontSize="11" />
                </Border>
                <TextBlock Grid.Column="4" Text="{Binding DateDisplay}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="8,0,0,0" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Page.Content>
        <Grid Padding="20" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock FontSize="20" FontWeight="SemiBold" Text="WinUI.TableView Samples" VerticalAlignment="Center" />

                <ToggleSwitch x:Name="ThemeToggleSwitch"
                              Grid.Column="1"
                              Header="Dark mode"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Toggled="OnThemeToggleToggled" />
            </Grid>

            <TabView Grid.Row="1">
                <TabViewItem Header="Features Demo">
                    <Grid Padding="8">
                        <tableView:TableView
                            AutoGenerateColumns="False"
                            ItemsSource="{x:Bind ProductRows}"
                            AlternateRowBackground="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerButtonMode="Options"
                            ShowExportOptions="True"
                            SelectionMode="Single">
                            <tableView:TableView.Columns>
                                <tableView:TableViewTextColumn Header="Product" Binding="{Binding Name}" MinWidth="200" />
                                <tableView:TableViewTextColumn Header="Category" Binding="{Binding Category}" MinWidth="140" />
                                <tableView:TableViewNumberColumn Header="Price" Binding="{Binding Price}" MinWidth="100" />
                                <tableView:TableViewNumberColumn Header="Stock" Binding="{Binding Stock}" MinWidth="90" />
                                <tableView:TableViewCheckBoxColumn Header="Available" Binding="{Binding IsAvailable}" MinWidth="100" />
                                <tableView:TableViewDateColumn Header="Added" Binding="{Binding DateAdded}" MinWidth="140" />
                                <tableView:TableViewComboBoxColumn Header="Rating" Binding="{Binding Rating}" MinWidth="120"
                                    ItemsSource="{x:Bind RatingOptions}" />
                            </tableView:TableView.Columns>
                        </tableView:TableView>
                    </Grid>
                </TabViewItem>

                <TabViewItem Header="File Explorer">
                    <Grid Padding="8">
                        <tableView:TableView
                            AutoGenerateColumns="False"
                            GroupByPath="GroupLabel"
                            HeadersVisibility="Columns"
                            ItemsSource="{x:Bind ExplorerRows}"
                            RowHeight="34"
                            RowMinHeight="30"
                            SelectionMode="Single"
                            ShowGroupItemCount="False">
                            <tableView:TableView.Columns>
                                <tableView:TableViewTemplateColumn Header="Name" CellTemplate="{StaticResource ExplorerNameTemplate}" MinWidth="340" />
                                <tableView:TableViewTextColumn Header="Date modified" Binding="{Binding DateModified}" MinWidth="170" />
                                <tableView:TableViewTextColumn Header="Type" Binding="{Binding Type}" MinWidth="180" />
                                <tableView:TableViewTextColumn Header="Size" Binding="{Binding Size}" MinWidth="120" />
                            </tableView:TableView.Columns>
                        </tableView:TableView>
                    </Grid>
                </TabViewItem>

                <TabViewItem Header="Task Manager">
                    <Grid Padding="8">
                        <tableView:TableView
                            AutoGenerateColumns="False"
                            ChildrenPath="Children"
                            GroupByPath="Category"
                            HeadersVisibility="Columns"
                            IndentSize="14"
                            IsExpandedPath="IsExpanded"
                            IsHierarchicalEnabled="True"
                            ItemsSource="{x:Bind TaskRows}"
                            RowHeight="34"
                            RowMinHeight="30"
                            SelectionMode="Single"
                            ShowGroupItemCount="True">
                            <tableView:TableView.Columns>
                                <tableView:TableViewTemplateColumn Header="Name" CellTemplate="{StaticResource TaskNameTemplate}" MinWidth="300" />
                                <tableView:TableViewTextColumn Header="Status" Binding="{Binding Status}" MinWidth="140" />
                                <tableView:TableViewTextColumn Header="CPU" Binding="{Binding Cpu}" MinWidth="90" />
                                <tableView:TableViewTextColumn Header="Memory" Binding="{Binding Memory}" MinWidth="130" />
                                <tableView:TableViewTextColumn Header="Disk" Binding="{Binding Disk}" MinWidth="100" />
                                <tableView:TableViewTextColumn Header="Network" Binding="{Binding Network}" MinWidth="110" />
                            </tableView:TableView.Columns>
                        </tableView:TableView>
                    </Grid>
                </TabViewItem>

                <TabViewItem Header="Row Template">
                    <Grid Padding="8" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Uses RowTemplate to render each row with a custom contact-card layout instead of column-based cells."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
                        <tableView:TableView
                            Grid.Row="1"
                            AutoGenerateColumns="False"
                            ItemsSource="{x:Bind ContactRows}"
                            RowTemplate="{StaticResource ContactRowTemplate}"
                            AlternateRowBackground="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            SelectionMode="Single"
                            HeadersVisibility="Columns">
                            <tableView:TableView.Columns>
                                <tableView:TableViewTextColumn Header="" MinWidth="40" MaxWidth="40" />
                                <tableView:TableViewTextColumn Header="Name" MinWidth="160" />
                                <tableView:TableViewTextColumn Header="Email" MinWidth="200" />
                                <tableView:TableViewTextColumn Header="Phone" MinWidth="120" />
                                <tableView:TableViewTextColumn Header="Status" />
                            </tableView:TableView.Columns>
                        </tableView:TableView>
                    </Grid>
                </TabViewItem>

                <TabViewItem Header="Row Template Selector">
                    <Grid Padding="8" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Uses RowTemplateSelector to pick a different template for high-priority orders vs. normal orders."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
                        <tableView:TableView
                            Grid.Row="1"
                            AutoGenerateColumns="False"
                            ItemsSource="{x:Bind OrderRows}"
                            AlternateRowBackground="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            SelectionMode="Single"
                            HeadersVisibility="Columns">
                            <tableView:TableView.Columns>
                                <tableView:TableViewTextColumn Header="Order ID" MinWidth="80" />
                                <tableView:TableViewTextColumn Header="Customer" MinWidth="160" />
                                <tableView:TableViewTextColumn Header="Total" MinWidth="100" />
                                <tableView:TableViewTextColumn Header="Priority" MinWidth="100" />
                                <tableView:TableViewTextColumn Header="Date" />
                            </tableView:TableView.Columns>
                            <tableView:TableView.RowTemplateSelector>
                                <local:OrderPriorityTemplateSelector
                                    HighPriorityTemplate="{StaticResource HighPriorityOrderTemplate}"
                                    NormalTemplate="{StaticResource NormalOrderTemplate}" />
                            </tableView:TableView.RowTemplateSelector>
                        </tableView:TableView>
                    </Grid>
                </TabViewItem>
            </TabView>
        </Grid>
    </Page.Content>
</Page>
